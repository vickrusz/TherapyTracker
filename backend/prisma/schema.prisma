generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id              Int      @id @default(autoincrement())
  nickname        String
  fullName        String
  initialEvalDate DateTime
  frequencyNotes  String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  address         String?
  phoneNumber     String?
  visits          Visit[]
}

model Visit {
  id                  Int                 @id @default(autoincrement())
  visitDate           DateTime
  visitType           String
  notes               String?
  createdAt           DateTime            @default(now())
  patientId           Int
  quickCapture        String?
  responseToTreatment String?
  totalMinutes        Int?
  patient             Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  interventions       VisitIntervention[]
}

model VisitIntervention {
  id              Int      @id @default(autoincrement())
  category        String
  minutes         Int
  createdAt       DateTime @default(now())
  visitId         Int
  clinicalDetails String?
  visit           Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
}
